{
  "name": "brainplex",
  "version": "0.1.0",
  "description": "Bundler + Configurator for the Vainplex OpenClaw Plugin Suite",
  "type": "module",
  "bin": {
    "brainplex": "bin/brainplex.mjs"
  },
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "files": [
    "dist/",
    "bin/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "openclaw",
    "brainplex",
    "vainplex",
    "ai-agents",
    "plugin-suite",
    "setup",
    "cli"
  ],
  "author": "Albert Hild <a.hild@vainplex.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alberthild/vainplex-openclaw.git",
    "directory": "packages/brainplex"
  }
}
